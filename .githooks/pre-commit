#!/usr/bin/env bash
# Block commits that include rebuilt web bundles in the embed-stub files.
#
# internal/web/dist/index.html and internal/web/dist-standalone/standalone.html
# exist only so `go:embed` resolves for Go-only contributors (gopls, go vet,
# go test). The real bundles are regenerated by `just build-web` /
# `just build-web-standalone` at release time and should never be committed.
#
# Enable with: just install-hooks
set -euo pipefail

stub_files=(
  internal/web/dist/index.html
  internal/web/dist-standalone/standalone.html
)

# A real bundle is orders of magnitude larger than the stub; 1KB is a safe
# ceiling that leaves room for minor stub edits without tripping on bundles.
max_bytes=1024

failed=0
staged=$(git diff --cached --name-only --diff-filter=ACM)

for f in "${stub_files[@]}"; do
  if grep -qx "$f" <<<"$staged"; then
    size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
    if [ "$size" -gt "$max_bytes" ]; then
      echo "pre-commit: $f is staged at $size bytes (limit $max_bytes)." >&2
      echo "  This file must stay as a small placeholder for go:embed." >&2
      echo "  To revert: git checkout HEAD -- $f" >&2
      failed=1
    fi
  fi
done

exit $failed
